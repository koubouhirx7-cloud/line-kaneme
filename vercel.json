{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/webhook/line",
      "dest": "api/index.py"
    },
    {
      "src": "/complete.html",
      "dest": "/complete.html"
    },
    {
      "src": "/liff.html",
      "dest": "/liff.html"
    },
    {
      "src": "/admin.html",
      "dest": "/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}